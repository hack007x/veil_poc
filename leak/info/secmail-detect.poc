## id: secmail-detect
## name: SecMail Login Panel - Detect
## author: hack007x
## severity: info
## tags: secmail,panel,discovery
## description: SecMail login panel was detected.
## shodan-query: secmail
## verification: true

GET /SecMail/login.jsp HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body contains "Path=/SecMail"
#@ matcher: status_code == 200





