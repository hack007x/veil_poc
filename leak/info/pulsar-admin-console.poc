## verification: true

GET /#/admin/dashboard HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body contains "<title>Pulsar Admin Console"
#@ matcher: status_code == 200





