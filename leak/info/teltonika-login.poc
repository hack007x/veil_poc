## verification: true

GET /cgi-bin/luci HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body matches /<title>Teltonika(.*) - Web UI<\/title>/
#@ matcher: status_code == 200





