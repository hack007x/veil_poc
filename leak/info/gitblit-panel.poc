## shodan-query: http.title:"Gitblit",http.title:"gitblit",http.html:"gitblit"
## fofa-query: body="gitblit",title="gitblit"
## verification: true

GET / HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ follow_redirects: true
#@ condition: and
#@ matcher: body contains "<title>Gitblit</title>" || body contains "Welcome to Gitblit"
#@ matcher: status_code == 200
