## reference: https://www.supermicro.com/white_paper/IPMI_white_paper.pdf
## shodan-query: http.title:"Supermicro BMC Login"
## verification: true

GET / HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body contains "<title>Supermicro BMC Login</title>"
#@ matcher: status_code == 200





