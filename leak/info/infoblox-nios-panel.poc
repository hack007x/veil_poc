## verification: true

GET /ui/ HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body contains "<title>Infoblox Grid" || body contains "<title>Infoblox System"
#@ matcher: status_code == 200





