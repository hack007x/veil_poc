## id: macos-server-panel
## name: macOS Server Panel - Detect
## author: hack007x
## severity: info
## tags: panel,login,macos-server,detect,discovery
## shodan-query: title:"macOS Server"
## verification: true

GET / HTTP/1.1
Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ condition: and
#@ matcher: body contains "macOS Server"
#@ matcher: body contains "apple-system"
#@ matcher: status_code == 200





