Host: {{Hostname}}
User-Agent: {{random_ua}}

#@ stop_scan: true
#@ condition: and
#@ matcher: header["content-type"] matches /(?i)content-type:\s*application\/(json|vnd\.postman\.[^;\s]+)/
#@ matcher: body matches /(?i)"info"\s*:\s*\{\s*"name"\s*:\s*".+?"/
#@ matcher: body matches /(?i)"item"\s*:\s*\[/
#@ matcher: status_code == 200

---

